# Server
PORT=3001
NODE_ENV=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agarramais_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_trocar_em_producao
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sua_openai_api_key_aqui
OPENAI_MODEL=gpt-4.1-mini

# Admin padrão
ADMIN_EMAIL=admin@agarramais.com
ADMIN_PASSWORD=Admin@123

# Machine Pay
MACHINE_PAY_LOGIN_URL=https://www.cyberpix.com.br/pix-adesivo-clientes/
MACHINE_PAY_LOGIN=seu_login_machine_pay
MACHINE_PAY_PASSWORD=sua_senha_machine_pay
MACHINE_PAY_API_TEMPLATE=https://www.cyberpix.com.br/pix-adesivo-clientes/maquinas.php?acao=stats&posid={posid}&dataini={inicio64}&datafim={fim64}&chave={chave}
MACHINE_PAY_CHAVE=
